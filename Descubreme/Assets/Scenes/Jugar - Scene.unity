--- !u!114 &1910652790
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1910652789}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 01216f75ddea37f47981516b874890ad, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::GameManager
  questions:
  - questionText: "\xBFEn qu\xE9 yacimiento espa\xF1ol puede visitarse el mosaico
      romano probablemente m\xE1s espectacular y mejor conservado del Imperio?"
    questionImage: {fileID: -5575309296871147705, guid: 87bc3aa7363528945a1f9848a3bdcd45, type: 3}
    answer:
    - answersText: Villa Romana de Noheda, Cuenca
      isCorrect: 1
    - answersText: Villa Romana La Olmeda, Palencia
      isCorrect: 0
    - answersText: "It\xE1lica, Sevilla"
      isCorrect: 0
    - answersText: "Parque Arqueol\xF3gico de Seg\xF3briga, Cuenca"
      isCorrect: 0
  - questionText: "\xBFEn qu\xE9 remoto enclave del norte de Espa\xF1a se encuentra
      la \xFAnica iglesia rupestre hispanovisigoda en la que a\xFAn se conservan
      pinturas originales del siglo VII?"
    questionImage: {fileID: -6911937752221260681, guid: 5d22a88c468f23f42b5a75c63590f608, type: 3}
    answer:
    - answersText: "Iglesia rupestre de Santa Mar\xEDa de Valverde, Valderredible"
      isCorrect: 1
    - answersText: "San Juan de la Pe\xF1a, Huesca"
      isCorrect: 0
    - answersText: "Ermita de San Bartolom\xE9, Ca\xF1\xF3n del R\xEDo Lobos"
      isCorrect: 0
    - answersText: "Santa Mar\xEDa de Lebe\xF1a, Cantabria"
      isCorrect: 0
  - questionText: "\xBFD\xF3nde puede encontrarse la ciudad medieval mejor amurallada
      de la provincia de Soria, famosa pero sorprendentemente poco visitada?"
    questionImage: {fileID: -1403030774163911143, guid: 9c4a36faacda9f94abc1946215048201, type: 3}
    answer:
    - answersText: Berlanga de Duero
      isCorrect: 1
    - answersText: "Calata\xF1azor"
      isCorrect: 0
    - answersText: Medinaceli
      isCorrect: 0
    - answersText: Vinuesa
      isCorrect: 0
  - questionText: "\xBFEn qu\xE9 peque\xF1o pueblo espa\xF1ol se hall\xF3 la necr\xF3polis
      celta con el mayor n\xFAmero de tumbas de guerreros vettones?"
    questionImage: {fileID: -9138421087659756323, guid: 8062f93ec8dfc104685e8452f1aa6822, type: 3}
    answer:
    - answersText: "Las Cogotas, \xC1vila"
      isCorrect: 1
    - answersText: Numancia, Soria
      isCorrect: 0
    - answersText: "Castro de Coa\xF1a, Asturias"
      isCorrect: 0
    - answersText: "Castro de Baro\xF1a, Galicia"
      isCorrect: 0
  - questionText: "\xBFEn qu\xE9 localidad extreme\xF1a se prepara una de las versiones
      m\xE1s antiguas \u2014y menos conocidas\u2014 del escabeche tradicional espa\xF1ol,
      transmitido desde la \xE9poca romana?"
    questionImage: {fileID: 127606795788759868, guid: 20771909a5decaa4c878150ddbab48bd, type: 3}
    answer:
    - answersText: "Alcu\xE9scar, C\xE1ceres"
      isCorrect: 1
    - answersText: "Trujillo, C\xE1ceres"
      isCorrect: 0
    - answersText: Zafra, Badajoz
      isCorrect: 0
    - answersText: Jerez de los Caballeros, Badajoz
      isCorrect: 0
  - questionText: "\xBFQu\xE9 cient\xEDfico espa\xF1ol fue pionero de la neurociencia
      moderna?"
    questionImage: {fileID: 0}
    answer:
    - answersText: "Santiago Ram\xF3n y Cajal"
      isCorrect: 1
    - answersText: "Gregorio Mara\xF1\xF3n"
      isCorrect: 0
    - answersText: Severo Ochoa
      isCorrect: 0
    - answersText: Blas Cabrera
      isCorrect: 0
  - questionText: "\xBFCu\xE1l de estas escritoras espa\xF1olas fue la primera mujer
      en ganar el Premio Cervantes?"
    questionImage: {fileID: -5081651036113354128, guid: 16b026446c48d9245b9d630520def408, type: 3}
    answer:
    - answersText: "Mar\xEDa Zambrano"
      isCorrect: 1
    - answersText: "Ana Mar\xEDa Matute"
      isCorrect: 0
    - answersText: "Carmen Mart\xEDn Gaite"
      isCorrect: 0
    - answersText: Almudena Grandes
      isCorrect: 0
  - questionText: "\xBFQu\xE9 alimento espa\xF1ol es considerado uno de los quesos
      m\xE1s antiguos documentados en Europa?"
    questionImage: {fileID: 0}
    answer:
    - answersText: Queso de Los Beyos
      isCorrect: 0
    - answersText: "Queso de Idiaz\xE1bal"
      isCorrect: 0
    - answersText: Queso Majorero
      isCorrect: 0
    - answersText: Queso de Cabrales
      isCorrect: 1
  - questionText: "\xBFQu\xE9 hero\xEDna legendaria de la Antig\xFCedad se asocia
      con una ciudad celt\xEDbera real del norte de Espa\xF1a?"
    questionImage: {fileID: -3157371423264886097, guid: 1720d8174b9e96442b210325836c5186, type: 3}
    answer:
    - answersText: Hipatia
      isCorrect: 0
    - answersText: Teodosia
      isCorrect: 0
    - answersText: Himilce
      isCorrect: 0
    - answersText: La Dama de Numancia
      isCorrect: 1
  - questionText: "\xBFQu\xE9 pintor espa\xF1ol del siglo XX revolucion\xF3 el arte
      abstracto y fue maestro del color?"
    questionImage: {fileID: -7483354719070496422, guid: 113792f679d6da949938080ef997bb85, type: 3}
    answer:
    - answersText: "Antoni T\xE0pies"
      isCorrect: 0
    - answersText: Pablo Picasso
      isCorrect: 0
    - answersText: "Joaqu\xEDn Torres-Garc\xEDa"
      isCorrect: 1
    - answersText: "Dar\xEDo de Regoyos"
      isCorrect: 0
